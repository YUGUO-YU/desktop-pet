{
  "name": "desktop-spirit",
  "version": "2.0.0",
  "description": "桌面精灵 V2.0 - 加菲猫",
  "main": "electron/main.js",
  "scripts": {
    "dev": "npm run build:electron && electron .",
    "build": "vite build",
    "build:electron": "tsc electron/main.ts --outDir electron --module commonjs --esModuleInterop --skipLibCheck",
    "build:preload": "tsc electron/preload.ts --outDir electron --module commonjs --esModuleInterop --skipLibCheck",
    "build:all": "npm run build:electron && npm run build:preload",
    "start": "electron ."
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}